<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         stopOnFailure="false"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="RA5 - Bloque A">
            <file>tests/Feature/BloqueATest.php</file>
        </testsuite>
        <testsuite name="RA6 - Bloque B">
            <file>tests/Feature/BloqueBTest.php</file>
        </testsuite>
        <testsuite name="RA7 - Bloque C">
            <file>tests/Feature/BloqueCTest.php</file>
        </testsuite>
    </testsuites>

    <!-- Extensión PHPUnit 10/11: sustituye al antiguo <listeners> -->
    <extensions>
        <bootstrap class="Tests\Support\PuntosExtension"/>
    </extensions>

    <!-- Base de datos SQLite en memoria: cada ejecución parte de cero -->
    <php>
        <env name="APP_ENV"              value="testing"/>
        <env name="DB_CONNECTION"        value="sqlite"/>
        <env name="DB_DATABASE"          value=":memory:"/>
        <env name="SESSION_DRIVER"       value="array"/>
        <env name="CACHE_DRIVER"         value="array"/>
        <env name="QUEUE_CONNECTION"     value="sync"/>
        <env name="SANCTUM_STATEFUL_DOMAINS" value="localhost"/>
    </php>

    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
</phpunit>
